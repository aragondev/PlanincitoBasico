{
  "name": "planincito",
  "private": true,
  "version": "0.1.0",
  "description": "Planning Poker temporal en tiempo real para equipos de hasta 8 personas",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "build:client": "npm run build --workspace client",
    "test": "npm run test --workspace server",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18"
  }
}
