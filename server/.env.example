# Puerto asignado por Render en producción.
PORT=3000

# Origen exacto del frontend. Varios orígenes separados por coma.
# En producción: https://usuario.github.io
CLIENT_ORIGIN=http://localhost:5173

# Frase compartida para entrar. Vacía o ausente = cualquiera puede conectarse.
# Defínela en Render para que la instancia sea privada.
ROOM_ACCESS_SECRET=
ACCESS_MAX_ATTEMPTS=10
ACCESS_ATTEMPT_WINDOW_MS=600000

# Protección de recursos en la instancia gratuita (§3.5).
MAX_ACTIVE_ROOMS=25
MAX_PARTICIPANTS_PER_ROOM=8
EMPTY_ROOM_GRACE_MS=60000
# Rondas guardadas por sala; el historial muere con la sala.
MAX_ROUND_HISTORY=50
DISCONNECTED_PARTICIPANT_GRACE_MS=60000
MAX_EVENT_PAYLOAD_BYTES=4096
RATE_LIMIT_WINDOW_MS=5000
RATE_LIMIT_MAX_EVENTS=60
CLEANUP_INTERVAL_MS=15000
SHUTDOWN_GRACE_MS=5000
